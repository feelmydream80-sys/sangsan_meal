{
  "version": 2,
  "name": "sangsan-meal",
  "rewrites": [
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/sw.js",
      "headers": {
        "Service-Worker-Allowed": "/",
        "Cache-Control": "no-cache"
      }
    },
    {
      "source": "/manifest.json",
      "headers": {
        "Content-Type": "application/manifest+json"
      }
    }
  ]
}