{
  "version": 2,
  "framework": null,
  "buildCommand": "echo 'No build required'",
  "outputDirectory": ".",
  "routes": [
    { "handle": "filesystem" },
    { "src": "/.*", "dest": "/index.html" }
  ],
  "headers": [
    {
      "source": "/sw.js",
      "headers": {
        "Service-Worker-Allowed": "/",
        "Cache-Control": "no-cache"
      }
    },
    {
      "source": "/manifest.json",
      "headers": {
        "Content-Type": "application/manifest+json"
      }
    }
  ]
}